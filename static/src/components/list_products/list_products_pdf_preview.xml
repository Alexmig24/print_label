<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="print_label.ListProducts.pdf_preview">
    <div class="border bg-light d-none d-sm-flex flex-column"
         style="min-width: 40%;"
         t-if="state.pdfData || state.generatingPdf" >

        <div class="p-3 bg-white border-bottom d-flex justify-content-between align-items-center">
            <h5 class="mb-0">
                <i class="fa fa-file-pdf-o text-danger me-2"/>
                Vista previa
            </h5>
            <div t-if="state.pdfData" class="d-flex gap-2">
                <button class="btn btn-sm btn-outline-secondary" t-on-click="clearPdf">
                    <i class="fa fa-times me-1"/>
                    Limpiar
                </button>
            </div>
        </div>

        <div class="flex-grow-1 d-flex align-items-center justify-content-center">
            <div t-if="!state.pdfData &amp;&amp; !state.generatingPdf"
                 class="text-center text-muted">
                <i class="fa fa-file-pdf-o fa-5x mb-3 opacity-25"/>
                <p class="h5">No hay PDF para mostrar</p>
                <p>Selecciona productos y haz click en "Generar PDF"</p>
            </div>

            <div t-if="state.generatingPdf"
                 class="text-center">
                <i class="fa fa-spinner fa-spin fa-3x text-primary mb-3"/>
                <p class="h5">Generando PDF...</p>
                <p class="text-muted">Por favor espera</p>
            </div>

            <iframe t-if="state.pdfData &amp;&amp; !state.generatingPdf"
                    t-att-src="state.pdfData"
                    class="w-100 h-100 border-0 rounded"/>
        </div>
    </div>
</t>

</templates>
