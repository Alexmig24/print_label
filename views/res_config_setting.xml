<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Heredar vista de configuración -->
        <record id="res_config_settings_view_form_print_label" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.print.label</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="stock.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//block[@name='operations_setting_container']" position="before">
                    <block title="Imprimir Etiquetas" name="print_label_settings_container">
                        <setting>
                            <label for="print_label_pricelist"/>
                            <div class="content-group">
                                <div class="text-muted">
                                    Permite escoger la lista de precio que saldra codificada en la etiqueta
                                </div>
                                <field name="print_label_pricelist"/>
                            </div>
                        </setting>
                        <setting>
                            <label for="print_label_template_id"/>
                            <div class="content-group">
                                <div class="text-muted">
                                    Selecciona la plantilla de etiqueta que se usará para imprimir
                                </div>
                                <field name="print_label_template_id"/>
                            </div>
                        </setting>
                    </block>
                </xpath>
            </field>
        </record>
    </data>
</odoo>